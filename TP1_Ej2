// Pinkus, Chama, Espinoza, G6

#include <U8g2lib.h>
#include <DHT.h>

#define DHTPIN 23
#define DHTTYPE DHT11

U8G2_SH1106_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE);
DHT dht(DHTPIN, DHTTYPE);

void setup() {
  Serial.begin(9600);
  u8g2.begin();
  dht.begin();
}

void loop() {
  float temp = dht.readTemperature();
  char stringtemp[10];

  if (isnan(temp)) return;

  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB14_tr);
  u8g2.drawStr(10,15,"TEMP");
  u8g2.setFont(u8g2_font_ncenB08_tr);

  sprintf(stringtemp,"%d",(int)temp);

  u8g2.drawStr(30,40,stringtemp);
  u8g2.drawStr(60,40,"C");
  u8g2.sendBuffer();

  delay(1500);
}
