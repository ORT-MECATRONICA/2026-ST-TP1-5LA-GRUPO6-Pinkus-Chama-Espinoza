// Pinkus, Chama, Espinoza, G6

#include <DHT.h>

#define DATA_DHT 23
#define DHTTYPE DHT11
#define LED_RELE 2
#define UMBRAL 28

DHT dht(DATA_DHT, DHTTYPE);
float temperatura = 0;

void setup() {
  Serial.begin(115200);
  dht.begin();
  pinMode(LED_RELE, OUTPUT);
}

void loop() {
  temperatura = dht.readTemperature();

  if (isnan(temperatura)) {
    Serial.println("Error al leer el sensor");
    return;
  }

  Serial.print("Temperatura: ");
  Serial.print(temperatura);
  Serial.println(" °C");

  if (temperatura >= UMBRAL) {
    digitalWrite(LED_RELE, HIGH);
    Serial.println("RELE/LED ENCENDIDO");
  } else {
    digitalWrite(LED_RELE, LOW);
    Serial.println("RELE/LED APAGADO");
  }
  delay(2000);
}
